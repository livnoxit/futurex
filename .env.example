# Copy to `.env.local` for local development.

VITE_API_BASE_URL=http://localhost:8080/api

# Tenant UUID from the Livnox admin dashboard (sent as X-Tenant-ID).
VITE_TENANT_ID=

# Website UUID from the Livnox admin dashboard (sent as X-Website-ID).
VITE_WEBSITE_ID=

# Form UUID from the admin dashboard (sent as formId in the submission body).
VITE_REGISTRATION_FORM_ID=

# Production values live in `.env.production` (used by `npm run build`).
